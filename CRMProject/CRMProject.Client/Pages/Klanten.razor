@page "/klanten"
@using CRMProject.Client.Pages.Components
<div class="d-flex justify-content-between align-items-center mb-3">
    <div style="flex: 1 1 0; min-width: 0;">
        @if (KlantenLijst.Count != 0)
        {
            <KlantenFilter KlantenLijst="KlantenLijst" OnFilterChanged="HandleFilterChanged" />
        }
    </div>
    <h1 style="flex: 1 1 0; min-width: 0;" class="text-center m-0">Klanten</h1>
    <div style="flex: 1 1 0; min-width: 0;" class="text-end">
        @if (KlantenLijst != null)
        {
            

                @if (KlantenLijst.Count == FilterLijst.Count)
                {
                    <span class="me-2">@KlantenLijst.Count Klanten</span>
                }
                else
                {
                    <span class="me-2">@FilterLijst.Count/@KlantenLijst.Count Klanten</span>
                }
            
        }


        <a href="/klanten/aanpassen" class="btn btn-success">
            <span class="bi bi-person-plus" aria-hidden="true"></span> Nieuwe Klant
        </a>
    </div>
</div>
@if (KlantenLijst.Count != 0)
{
    <KlantenTable FilterLijst="FilterLijst" />
}
else if (!firstRender)
{
    <p>Laden...</p>
}
else
{
    <p class="text-danger">Er zijn geen Klanten gevonden!</p>
}


@code {
    [Inject]
    public KlantenService klantenService { get; set; }
    List<Klant> KlantenLijst = new List<Klant>();
    List<Klant> FilterLijst = new List<Klant>();
    bool firstRender = false;

    protected override async Task OnInitializedAsync()
    {
        KlantenLijst = await klantenService.GetKlantenAsync();
        FilterLijst = KlantenLijst;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        this.firstRender = firstRender;
    }

    private void HandleFilterChanged(List<Klant> filteredList)
    {
        FilterLijst = filteredList;
    }
}