@page "/klanten"
<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="flex-grow-1"></div>
    <h1 class="flex-grow-1 text-center m-0">Klanten</h1>
    <div class="flex-grow-1 text-end">
        <a href="/klanten/aanpassen" class="btn btn-success">
            <span class="bi bi-person-plus" aria-hidden="true"></span> Nieuwe Klant
        </a>
    </div>
</div>
@if (KlantenLijst.Count != 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover border rounded">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Email</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (Klant klant in KlantenLijst)
                {
                    <tr>
                        <td>
                            @klant.Voornaam @klant.Naam
                        </td>
                        <td>
                            @klant.EmailAdres
                        </td>
                        <td>
                            <a href="/klanten/@klant.Id" class="text-decoration-none" title="Details">
                                <span class="bi bi-eye" aria-hidden="true"></span>
                            </a>
                            <span> | </span>
                            <a href="/klanten/aanpassen/@klant.Id" class="text-decoration-none" title="Bewerk">
                                <span class="bi bi-pencil" aria-hidden="true"></span>
                            </a>
                            <span> | </span>
                            <a href="/klanten/Deleteconfirm/@klant.Id/@klant.Voornaam @klant.Naam" class="text-decoration-none text-danger" title="Verwijder">
                                <span class="bi bi-trash" aria-hidden="true"></span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}


@code {
    [Inject]
    public KlantenService klantenService { get; set; }
    List<Klant> KlantenLijst = new List<Klant>();

    protected override async Task OnInitializedAsync()
    {
        KlantenLijst = await klantenService.GetKlantenAsync();
    }

}
