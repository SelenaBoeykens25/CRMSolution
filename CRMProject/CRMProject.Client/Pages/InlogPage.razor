@page "/login"
@rendermode InteractiveWebAssembly
@using CRM.Models
@using Blazored.SessionStorage
@using CRMProject.Client.Services
@inject AuthenticationNotificationService AuthNotification

<div class="login-container">
    <div class="login-card">
        <h3 class="login-title">Inloggen</h3>

        <EditForm Model="@account" OnValidSubmit="@HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="account.Email" class="form-control" placeholder="voorbeeld@email.com" />
                <ValidationMessage For="@(() => account.Email)" />
            </div>

            <div class="form-group">
                <label for="wachtwoord">Wachtwoord</label>
                <InputText id="wachtwoord" type="password" @bind-Value="account.Wachtwoord" class="form-control" placeholder="Voer uw wachtwoord in" />
                <ValidationMessage For="@(() => account.Wachtwoord)" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            <button type="submit" class="btn btn-primary btn-login" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Inloggen...</span>
                }
                else
                {
                    <span>Inloggen</span>
                }
            </button>
        </EditForm>

        <div class="mt-3">
            <button type="button" class="btn btn-secondary btn-sm w-100" @onclick="ToggleAccountsTable">
                @if (showAccountsTable)
                {
                    <span class="bi bi-eye-slash me-2"></span>
                    <span>Verberg Accounts</span>
                }
                else
                {
                    <span class="bi bi-eye me-2"></span>
                    <span>Toon Accounts</span>
                }
            </button>
        </div>

        @if (showAccountsTable)
        {
            <div class="mt-3">
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Wachtwoord</th>
                            <th>Security Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>user@user.com</td>
                            <td>user123</td>
                            <td><span class="badge bg-info">User</span></td>
                        </tr>
                        <tr>
                            <td>admin@admin.com</td>
                            <td>admin123</td>
                            <td><span class="badge bg-warning">Admin</span></td>
                        </tr>
                        <tr>
                            <td>owner@owner.com</td>
                            <td>owner123</td>
                            <td><span class="badge bg-success">Owner</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Inject]
    AccountService accountService { get; set; }

    [Inject]
    NavigationManager navigationManager { get; set; }

    [Inject]
    ISessionStorageService sessionStorage { get; set; }

    GebruikersAccount account { get; set; } = new GebruikersAccount();

    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool hasCheckedLogin = false;
    private bool showAccountsTable = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasCheckedLogin)
        {
            hasCheckedLogin = true;
            // Als al ingelogd stuur terug
            var loggedInEmail = await sessionStorage.GetItemAsync<string>("loggedInEmail");
            if (!string.IsNullOrEmpty(loggedInEmail))
            {
                navigationManager.NavigateTo("/");
            }
        }
    }

    private void ToggleAccountsTable()
    {
        showAccountsTable = !showAccountsTable;
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var result = await accountService.LoginAsync(account.Email, account.Wachtwoord);

            if (result != null)
            {
                await sessionStorage.SetItemAsync("loggedInEmail", account.Email);
                await sessionStorage.SetItemAsync("securityLevel", result.SecurityLevel.ToString());
               
                AuthNotification.NotifyAuthenticationChanged();
                
                navigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = "Ongeldige email of wachtwoord. Probeer het opnieuw.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Er is een fout opgetreden. Probeer het later opnieuw.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
