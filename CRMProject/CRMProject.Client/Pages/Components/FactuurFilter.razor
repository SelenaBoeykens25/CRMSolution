@using CRM.Models.Enums
@inject NavigationManager NavigationManager
<EditForm OnSubmit="HandleFilter" Model="filterVariabele" class="d-flex gap-2 align-items-center">
    @if (filterVariabele.filterOp == "Nummer" || filterVariabele.filterOp == "Aantal" || filterVariabele.filterOp == "Prijs")
    {
        @if (filterVariabele.filterOp == "Nummer")
        {
            <InputNumber @bind-Value="filterVariabele.filterNummer" class="form-control" style="width: 200px;" placeholder="nummer" />
        }
        else if (filterVariabele.filterOp == "Prijs")
        {
            <InputNumber @bind-Value="filterVariabele.filterNummer" class="form-control" style="width: 200px;" placeholder="prijs" />
        }
        else
        {
            <InputNumber @bind-Value="filterVariabele.filterNummer" class="form-control" style="width: 200px;" placeholder="aantal" />
        }
        <InputSelect @bind-Value="filterVariabele.vergelijkingsOperator" class="form-select" style="width: 200px;">
            <option Value="@("=")">=</option>
            <option Value="@(">")">&gt;</option>
            <option Value="@("<")">&lt;</option>
        </InputSelect>
    }
    else if (filterVariabele.filterOp == "Klant")
    {   
        <InputText @bind-Value="filterVariabele.filter" class="form-control" style="width: 400px;" autofocus />
    }
    else if(filterVariabele.filterOp == "Status")
    {
        <InputSelect @bind-Value="filterVariabele.filterStatus" class="form-select" style="width: 300px;">
            @foreach (var statusoptie in Enum.GetValues(typeof(CRM.Models.Enums.BetaalStatus)))
            {
                <option value="@statusoptie">@statusoptie</option>
            }
        </InputSelect>
    }
    else
    {
        <InputSelect @bind-Value="filterVariabele.filterDatumSoort" class="form-select">
            <option Value="@("Dag")">Dag</option>
            <option Value="@("Maand")">Maand</option>
            <option Value="@("Jaar")">Jaar</option>
        </InputSelect>
        @if(filterVariabele.filterDatumSoort == "Dag")
        {   
        <InputDate @bind-Value="filterVariabele.filterDag" class="form-control"></InputDate>
        }
        @if (filterVariabele.filterDatumSoort == "Jaar" || filterVariabele.filterDatumSoort == "Maand")
        {
            @if(filterVariabele.filterDatumSoort == "Maand")
            {
                <InputNumber placeholder="maand" min="1" max="12" @bind-Value="filterVariabele.filterMaand" class="form-control" style="max-width: 120px;"></InputNumber>
            }

            <InputNumber placeholder="jaar" @bind-Value="filterVariabele.filterJaar" class="form-control" style="max-width: 120px;"></InputNumber>
        }
    }
    <InputSelect @bind-Value="filterVariabele.filterOp" class="form-select" style="width: 150px;">
        <option Value="@("Nummer")">Nummer</option>
        <option Value="@("Klant")">Klant</option>
        <option Value="@("Datum")">Datum</option>
        <option Value="@("TBV")">Betalen Voor</option>
        <option Value="@("Aantal")">Aantal Lijnen</option>
        <option Value="@("Prijs")">Prijs</option>
        <option Value="@("Status")">Betaalstatus</option>
    </InputSelect>
    <button type="submit" class="btn btn-primary flex-shrink-0"><span class="bi bi-search"></span> Filter</button>
</EditForm>

@code {
    [Parameter]
    public List<Factuur> FactuurLijst { get; set; } = new();

    [Parameter]
    public EventCallback<List<Factuur>> OnFilterChanged { get; set; }

    [Parameter]
    public Dictionary<string, string> InitialQueryParams { get; set; } = new();

    private class FilterModel
    {
        public string filter { get; set; } = "";
        public string filterOp { get; set; } = "Klant";
        public string filterDatumSoort { get; set; } = "Dag";
        public int filterJaar { get; set; } = DateTime.Today.Year;
        public int filterMaand { get; set; } = DateTime.Today.Month;
        public DateOnly filterDag { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string vergelijkingsOperator { get; set; } = "=";
        public decimal filterNummer { get; set; }
        public BetaalStatus filterStatus { get; set; }
    }

    private FilterModel filterVariabele = new FilterModel();
    private bool isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && InitialQueryParams != null && InitialQueryParams.Count > 0)
        {
            ApplyQueryParameters();
            await HandleFilter();
            StateHasChanged();
        }
    }

    private void ApplyQueryParameters()
    {
        if (InitialQueryParams.TryGetValue("filterOp", out var filterOp))
        {
            filterVariabele.filterOp = filterOp;
        }

        if (InitialQueryParams.TryGetValue("klant", out var klant))
        {
            filterVariabele.filter = klant;
        }

        if (InitialQueryParams.TryGetValue("nummer", out var nummerStr) && decimal.TryParse(nummerStr, out var nummer))
        {
            filterVariabele.filterNummer = nummer;
        }

        if (InitialQueryParams.TryGetValue("prijs", out var prijsStr) && decimal.TryParse(prijsStr, out var prijs))
        {
            filterVariabele.filterNummer = prijs;
        }

        if (InitialQueryParams.TryGetValue("aantal", out var aantalStr) && decimal.TryParse(aantalStr, out var aantal))
        {
            filterVariabele.filterNummer = aantal;
        }

        if (InitialQueryParams.TryGetValue("operator", out var op))
        {
            filterVariabele.vergelijkingsOperator = op;
        }

        if (InitialQueryParams.TryGetValue("status", out var statusStr) && Enum.TryParse<BetaalStatus>(statusStr, out var status))
        {
            filterVariabele.filterStatus = status;
        }

        if (InitialQueryParams.TryGetValue("datumSoort", out var datumSoort))
        {
            filterVariabele.filterDatumSoort = datumSoort;
        }

        if (InitialQueryParams.TryGetValue("jaar", out var jaarStr) && int.TryParse(jaarStr, out var jaar))
        {
            filterVariabele.filterJaar = jaar;
        }

        if (InitialQueryParams.TryGetValue("maand", out var maandStr) && int.TryParse(maandStr, out var maand))
        {
            filterVariabele.filterMaand = maand;
        }

        if (InitialQueryParams.TryGetValue("dag", out var dagStr) && DateOnly.TryParse(dagStr, out var dag))
        {
            filterVariabele.filterDag = dag;
        }
    }

    private async Task HandleFilter()
    {
        List<Factuur> filteredList = filterVariabele.filterOp switch
        {
            "Nummer" => ApplyNumericFilter(FactuurLijst, f => f.Id, filterVariabele.filterNummer, filterVariabele.vergelijkingsOperator),
            "Klant" => !string.IsNullOrEmpty(filterVariabele.filter)
                ? FactuurLijst.Where(factuur =>
                    ($"{factuur.Klant.Voornaam.ToLower()} {factuur.Klant.Naam.ToLower()}").Contains(filterVariabele.filter.ToLower())).ToList()
                : FactuurLijst,
            "Datum" => filterVariabele.filterDatumSoort switch
            {
                "Dag" => FactuurLijst.Where(f => 
                    f.FactuurDatum == filterVariabele.filterDag).ToList(),
                "Maand" => FactuurLijst.Where(f => 
                    f.FactuurDatum.Month == filterVariabele.filterMaand && 
                    f.FactuurDatum.Year == filterVariabele.filterJaar).ToList(),
                "Jaar" => FactuurLijst.Where(f => 
                    f.FactuurDatum.Year == filterVariabele.filterJaar).ToList(),
                _ => FactuurLijst
            },
            "TBV" => filterVariabele.filterDatumSoort switch
            {
                "Dag" => FactuurLijst.Where(f =>
                    f.TeBetalenVoor == filterVariabele.filterDag).ToList(),
                "Maand" => FactuurLijst.Where(f =>
                    f.TeBetalenVoor.Month == filterVariabele.filterMaand &&
                    f.TeBetalenVoor.Year == filterVariabele.filterJaar).ToList(),
                "Jaar" => FactuurLijst.Where(f =>
                    f.TeBetalenVoor.Year == filterVariabele.filterJaar).ToList(),
                _ => FactuurLijst
            },
            "Aantal" => ApplyNumericFilter(FactuurLijst, f => f.FactuurLijnen.Count, filterVariabele.filterNummer, filterVariabele.vergelijkingsOperator),
            "Status" => FactuurLijst.Where(f=> f.BetaalStatus == filterVariabele.filterStatus).ToList(),
            "Prijs" => ApplyNumericFilter(FactuurLijst, f => f.Prijs, filterVariabele.filterNummer, filterVariabele.vergelijkingsOperator),
            _ => FactuurLijst
        };
        await OnFilterChanged.InvokeAsync(filteredList);
    }

    private List<Factuur> ApplyNumericFilter<T>(List<Factuur> list, Func<Factuur, T> selector, T filterValue, string operatorSymbol) 
        where T : IComparable<T>
    {
        return operatorSymbol switch
        {
            "=" => list.Where(f => selector(f).CompareTo(filterValue) == 0).ToList(),
            ">" => list.Where(f => selector(f).CompareTo(filterValue) > 0).ToList(),
            "<" => list.Where(f => selector(f).CompareTo(filterValue) < 0).ToList(),
            _ => list
        };
    }
}