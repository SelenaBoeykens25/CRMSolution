<div class="table-responsive">
    <table class="table table-striped table-hover border rounded">
        <thead>
            <tr>
                <th>FactuurNummer</th>
                <th>Klant</th>
                <th>Datum</th>
                <th>Te Betalen Voor</th>
                <th>Prijs</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (Factuur factuur in FilterLijst)
            {
                <tr>
                    <td>
                        @factuur.Id
                    </td>
                    <td>
                        @factuur.Klant.Voornaam @factuur.Klant.Naam
                    </td>
                    <td>
                        @factuur.FactuurDatum
                    </td>
                    <td>
                        @factuur.TeBetalenVoor
                    </td>
                    <td>
                        &#8364; @factuur.Prijs
                    </td>
                    <td>
                        <a href="/facturen/@factuur.Id" class="text-decoration-none" title="Details">
                            <span class="bi bi-eye" aria-hidden="true"></span>
                        </a>
                        <span> | </span>
                        <a href="/facturen/aanpassen/@factuur.Id" class="text-decoration-none" title="Bewerk">
                            <span class="bi bi-pencil" aria-hidden="true"></span>
                        </a>
                        <span> | </span>
                        <a href="/facturen/Deleteconfirm/@factuur.Id" class="text-decoration-none text-danger" title="Verwijder">
                            <span class="bi bi-trash" aria-hidden="true"></span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<Factuur> FilterLijst { get; set; } = new();
}