@inject NavigationManager NavigationManager

<EditForm OnSubmit="HandleFilter" Model="filterVariabele">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-6 col-lg-6">
            <InputText @bind-Value="filterVariabele.filter" class="form-control" autofocus placeholder="Zoek..." />
        </div>
        
        <div class="col-12 col-md-4 col-lg-3">
            <InputSelect @bind-Value="filterVariabele.filterOp" class="form-select">
                <option Value="@("Naam")">Naam</option>
                <option Value="@("Email")">Email</option>
                <option Value="@("Telefoon")">Telefoon</option>
                <option Value="@("Adres")">Adres</option>
            </InputSelect>
        </div>
        
        <div class="col-12 col-md-2 col-lg-3">
            <button type="submit" class="btn btn-primary w-100">
                <span class="bi bi-search"></span> Filter
            </button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter]
    public List<Klant> KlantenLijst { get; set; } = new();

    [Parameter]
    public EventCallback<List<Klant>> OnFilterChanged { get; set; }

    [Parameter]
    public Dictionary<string, string> InitialQueryParams { get; set; } = new();

    private class FilterModel
    {
        public string filter { get; set; } = "";
        public string filterOp { get; set; } = "Naam";
    }

    private FilterModel filterVariabele = new FilterModel();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && InitialQueryParams != null && InitialQueryParams.Count > 0)
        {
            ApplyQueryParameters();
            await HandleFilter();
            StateHasChanged();
        }
    }

    private void ApplyQueryParameters()
    {
        if (InitialQueryParams.TryGetValue("filterOp", out var filterOp))
        {
            filterVariabele.filterOp = filterOp;
        }

        if (InitialQueryParams.TryGetValue("filter", out var filter))
        {
            filterVariabele.filter = filter;
        }
    }

    private async Task HandleFilter()
    {
        List<Klant> filteredList;

        if (!string.IsNullOrEmpty(filterVariabele.filter))
        {
            filteredList = filterVariabele.filterOp switch
            {
                "Naam" => KlantenLijst.Where(klant =>
                    ($"{klant.Voornaam.ToLower()} {klant.Naam.ToLower()}").Contains(filterVariabele.filter.ToLower())).ToList(),
                "Email" => KlantenLijst.Where(klant =>
                    klant.EmailAdres.Contains(filterVariabele.filter.ToLower())).ToList(),
                "Telefoon" => KlantenLijst.Where(klant =>
                    klant.TelefoonNummer.Contains(filterVariabele.filter.ToLower())).ToList(),
                "Adres" => KlantenLijst.Where(klant =>
                    (klant.Adres != null) &&
                    ($"{(klant.Adres.Straat ?? "").ToLower()} {(klant.Adres.HuisNummer ?? "").ToLower()} {(klant.Adres.BusNummer ?? "").ToLower()} {(klant.Adres.Stad ?? "").ToLower()}").Contains(filterVariabele.filter.ToLower())).ToList(),
                _ => KlantenLijst
            };
        }
        else
        {
            filteredList = KlantenLijst;
        }
        await OnFilterChanged.InvokeAsync(filteredList);
    }
}