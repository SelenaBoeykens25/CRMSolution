@page "/nieuwaccount/{email}"
@inherits AuthenticatedPageBase

<div class="d-flex flex-column justify-content-center align-items-center mt-5">
    <h1 class="mb-4">Account met email: @Email toegevoegd!</h1>
    <div>
        <a class="btn btn-success me-2" href="">Terug naar Home</a>
    </div>
</div>
@code {
    [Parameter]
    public string Email{ get; set; }
}
