@page "/nieuwaccount"
@rendermode InteractiveWebAssembly
@using CRM.Models
@using CRM.Models.Enums
@using CRMProject.Client.Services
@using Blazored.SessionStorage
@using System.ComponentModel.DataAnnotations
@inject AccountService accountService
@inject NavigationManager NavigationManager
@inject ISessionStorageService SessionStorage

<div class="container mt-4">
    <h3>Nieuw Account</h3>
    
    <EditForm Model="@nieuwAccount" OnValidSubmit="@HandleSubmit">
        <DataAnnotationsValidator />
        
        <div class="form-group mb-3">
            <label for="newmail">Email</label>
            <InputText autofocus id="nieuw-email" autocomplete="username" @bind-Value="nieuwAccount.Email" class="form-control" type="email"/>
            <ValidationMessage For="@(() => nieuwAccount.Email)" />
        </div>

        <div class="form-group mb-3">
            <label for="nieuw-wachtwoord">Wachtwoord</label>
            <InputText id="nieuw-wachtwoord" autocomplete="new-password" type="password" @bind-Value="nieuwAccount.Wachtwoord" class="form-control" />
            <ValidationMessage For="@(() => nieuwAccount.Wachtwoord)" />
        </div>
        <div class="form-group mb-3">
            <label for="herhaal-wachtwoord">Herhaal Wachtwoord</label>
            <InputText id="herhaal-wachtwoord" autocomplete="new-password" type="password" @bind-Value="nieuwAccount.HerhaaldWachtwoord" class="form-control" />
            <ValidationMessage For="@(() => nieuwAccount.HerhaaldWachtwoord)" />
        </div>


        @if (isOwner)
        {
            <div class="form-group mb-3">
                <label for="securityLevel">SecurityLevel</label>
                <InputSelect id="securityLevel" @bind-Value="nieuwAccount.SecurityLevel" class="form-control">
                    <option value="">-- Selecteer SecurityLevel --</option>
                    @foreach (var level in Enum.GetValues<SecurityLevel>())
                    {
                        <option value="@level">@level</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => nieuwAccount.SecurityLevel)" />
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <button type="submit" class="btn btn-primary" disabled="@isLoading">Opslaan</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuleren</button>
    </EditForm>
</div>

@code {
    private AccountViewModel nieuwAccount = new AccountViewModel();
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool isOwner = false;

    public class AccountViewModel
    {
        [DataType(DataType.EmailAddress)]
        [Required(ErrorMessage = "{0} is een verplicht veld!")]
        public string Email { get; set; } = "";
        [DataType(DataType.Password)]
        [Required(ErrorMessage = "{0} is een verplicht veld!")]
        public string Wachtwoord { get; set; } = "";
        [DataType(DataType.Password)]
        [Required(ErrorMessage = "{0} is een verplicht veld!")]
        public string HerhaaldWachtwoord { get; set; } = "";
        public SecurityLevel SecurityLevel { get; set; } = SecurityLevel.User;
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var securityLevel = await SessionStorage.GetItemAsync<string>("securityLevel");
            isOwner = securityLevel == "Owner";
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var bestaatAl = await accountService.BestaatAlAsync(nieuwAccount.Email);
            if (bestaatAl)
            {
                errorMessage = "Dit email adres bestaat al.";
                isLoading = false;
                return;
            }
            if(nieuwAccount.Wachtwoord != nieuwAccount.HerhaaldWachtwoord)
            {
                errorMessage = "Wachtwoorden komen niet overeen.";
                isLoading = false;
                return;
            }

            GebruikersAccount account = new GebruikersAccount
                {
                    Email = nieuwAccount.Email,
                    Wachtwoord = nieuwAccount.Wachtwoord,
                    SecurityLevel = nieuwAccount.SecurityLevel
                };


            var result = await accountService.AddAccountAsync(account);
            if (result != null)
            {
                NavigationManager.NavigateTo($"nieuwaccount/{account.Email}");
            }
            else
            {
                errorMessage = "Er is een fout opgetreden bij het aanmaken van het account.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/");
    }
}
