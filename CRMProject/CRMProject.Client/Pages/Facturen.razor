@page "/facturen"
@inject NavigationManager NavigationManager
@using CRMProject.Client.Pages.Components
<div class="d-flex justify-content-between align-items-center mb-3">
    <div style="flex: 1 1 0; min-width: 0;">
        @if (FactuurLijst.Count != 0)
        {
            <FactuurFilter FactuurLijst="FactuurLijst" 
                          OnFilterChanged="HandleFilterChanged" 
                          InitialQueryParams="queryParams" />
        }
    </div>
    <h1 style="flex: 1 1 0; min-width: 0;" class="text-center m-0">Facturen</h1>
    <div style="flex: 1 1 0; min-width: 0;" class="text-end">
        @if (FactuurLijst != null)
        {
            <span id="factuurTotaal" class="me-3">
                @if (FactuurLijst.Count == FilterLijst.Count)
                {
                    <span class="me-1">@FactuurLijst.Count</span>
                }
                else
                {
                    <span class="me-1">@FilterLijst.Count/@FactuurLijst.Count</span>
                }
                <span>
                    @((FactuurLijst.Count != 1) ? "Facturen" : "Factuur")
                </span>
            </span>
            
        }


        <a href="/facturen/aanpassen" class="btn btn-success">
            <span class="bi bi-file-earmark-diff" aria-hidden="true"></span> Nieuwe Factuur
        </a>
    </div>
</div>
@if (FactuurLijst.Count != 0)
{
    <FactuurTable FilterLijst="FilterLijst" />
}
else if (!firstRender)
{
    <p>Laden...</p>
}
else
{
    <p class="text-danger">Er zijn geen Facturen gevonden!</p>
}



@code {
    List<Factuur> FacturenLijst = new List<Factuur>();

    [Inject]
    public FactuurService factuurService { get; set; }
    List<Factuur> FactuurLijst = new List<Factuur>();
    List<Factuur> FilterLijst = new List<Factuur>();
    bool firstRender = false;
    Dictionary<string, string> queryParams = new();

    protected override async Task OnInitializedAsync()
    {
        FactuurLijst = await factuurService.GetFacturenAsync();
        FilterLijst = FactuurLijst;

        // Parse query parameters from URL
        var uri = new Uri(NavigationManager.Uri);
        if (!string.IsNullOrEmpty(uri.Query))
        {
            var query = uri.Query.TrimStart('?');
            var pairs = query.Split('&');
            foreach (var pair in pairs)
            {
                var parts = pair.Split('=');
                if (parts.Length == 2)
                {
                    queryParams[Uri.UnescapeDataString(parts[0])] = Uri.UnescapeDataString(parts[1]);
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        this.firstRender = firstRender;
    }

    private void HandleFilterChanged(List<Factuur> filteredList)
    {
        FilterLijst = filteredList;
    }
}
